###############################################################################
# .env.example
# Template for environment-specific configuration of the IAM platform.
#
# Copy this file to .env (or .env.dev, .env.qa, .env.prod) and adjust
# the values for your target environment.
#
# IMPORTANT: Never commit actual secrets to version control. Use
# Kubernetes Secrets or a secrets manager for production credentials.
###############################################################################

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# Target environment identifier: dev, qa, or prod.
IAM_ENV=dev

# ---------------------------------------------------------------------------
# Keycloak Configuration
# ---------------------------------------------------------------------------
# Base URL for the Keycloak instance (no trailing slash).
KC_BASE_URL=http://localhost:8080

# Admin credentials for the master realm.
# In production, use Kubernetes Secrets instead of this file.
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme

# Keycloak hostname (for production, set to the external FQDN).
KC_HOSTNAME=localhost

# HTTP and management ports exposed by Docker Compose.
KC_HTTP_PORT=8080
KC_MGMT_PORT=9000

# Keycloak log level: trace, debug, info, warn, error, fatal.
KC_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# PostgreSQL Configuration
# ---------------------------------------------------------------------------
# Database connection settings for Keycloak's persistence layer.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Monitoring Configuration
# ---------------------------------------------------------------------------
# Prometheus port for metrics collection.
PROMETHEUS_PORT=9090

# Grafana admin credentials and port.
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# OpenTelemetry Configuration
# ---------------------------------------------------------------------------
# OTel Collector endpoint for application tracing.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Jaeger endpoint for trace visualization.
JAEGER_ENDPOINT=jaeger:4317

# Environment label applied to all telemetry signals.
OTEL_ENVIRONMENT=dev

# ---------------------------------------------------------------------------
# Fluent Bit / Loki Configuration
# ---------------------------------------------------------------------------
# Loki endpoint for centralized log aggregation.
LOKI_HOST=loki
LOKI_PORT=3100

# Environment label for log records.
FLUENT_ENV=dev

# ---------------------------------------------------------------------------
# Backup Configuration
# ---------------------------------------------------------------------------
# Directory for storing database and realm backups.
BACKUP_DIR=./backups

# Number of days to retain old backup files before rotation.
BACKUP_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Kubernetes Configuration (for scripts)
# ---------------------------------------------------------------------------
# Path to kubeconfig file. Leave empty to use default cluster config.
# KUBECONFIG=/path/to/kubeconfig

# Default namespace for IAM resources.
K8S_NAMESPACE=iam

# ---------------------------------------------------------------------------
# GCP / GKE Configuration
# ---------------------------------------------------------------------------
# Google Cloud project ID for container registry and GKE.
# GCR_PROJECT_ID=my-project-id

# GKE cluster name and region for deployment scripts.
# GKE_CLUSTER_NAME=iam-cluster
# GKE_REGION=europe-west1

# ---------------------------------------------------------------------------
# Script Configuration
# ---------------------------------------------------------------------------
# Log level for operational scripts: debug, info, warn, error.
LOG_LEVEL=info

# Log format: text (colored) or json (structured).
LOG_FORMAT=text
