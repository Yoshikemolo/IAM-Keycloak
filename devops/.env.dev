# =============================================================================
# IAM Platform - Development Environment Variables
# =============================================================================
# This file contains environment-specific configuration for the development
# environment. It is loaded by docker-compose.base.yml and quick-start.sh.
#
# IMPORTANT: Never commit secrets to version control. In development, these
# placeholder values are acceptable. In production, use Kubernetes Secrets
# or a secret management solution (GCP Secret Manager, HashiCorp Vault).
# =============================================================================

# -- Environment identifier ---------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# -- Keycloak -----------------------------------------------------------------
KEYCLOAK_VERSION=26.4.2
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_HTTPS_PORT=8443
KEYCLOAK_MANAGEMENT_PORT=9000
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_PROXY_HEADERS=xforwarded
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_FEATURES=token-exchange,admin-fine-grained-authz,declarative-user-profile

# -- Database -----------------------------------------------------------------
DB_VENDOR=postgres
DB_ADDR=postgres
DB_PORT=5432
DB_DATABASE=keycloak
DB_SCHEMA=public
DB_USER=keycloak
DB_PASSWORD=keycloak_dev_password

# -- PostgreSQL container -----------------------------------------------------
POSTGRES_VERSION=16.6-alpine
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_dev_password

# -- Observability ------------------------------------------------------------
PROMETHEUS_VERSION=2.55.1
GRAFANA_VERSION=11.4.0
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
OTEL_COLLECTOR_VERSION=0.115.1

# -- Network ------------------------------------------------------------------
NETWORK_SUBNET=172.28.0.0/16
