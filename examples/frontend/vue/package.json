{
  "name": "iam-vue-example",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Vue 3.5 IAM example with Keycloak OIDC integration",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext ts,vue --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "oidc-client-ts": "^3.1.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.0",
    "vue-i18n": "^10.0.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
