# ---------------------------------------------------------------------------
# Environment variable reference for the Angular IAM Example.
#
# Angular does NOT read .env files at runtime. Instead, these values must be
# reflected in the environment files:
#   - src/environments/environment.ts       (development)
#   - src/environments/environment.prod.ts  (production)
#
# This file exists only as a reference for operators and CI/CD pipelines.
# ---------------------------------------------------------------------------

NG_KEYCLOAK_URL=http://localhost:8080
NG_KEYCLOAK_REALM=iam-demo
NG_KEYCLOAK_CLIENT_ID=iam-angular-app
