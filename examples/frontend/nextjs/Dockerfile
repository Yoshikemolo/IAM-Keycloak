# ---------------------------------------------------------------------------
# Dockerfile for the IAM Next.js Example application.
#
# Multi-stage build:
#   Stage 1 (deps)    - Installs production dependencies only.
#   Stage 2 (build)   - Installs all dependencies and produces an optimized
#                        standalone production bundle via Next.js.
#   Stage 3 (runtime) - Runs the Node.js standalone server with minimal
#                        footprint.
#
# Security considerations:
#   - Runs as a non-root user (nextjs).
#   - Uses read-only root filesystem where possible.
#   - Healthcheck ensures the container is responsive.
#
# Note: This project uses `output: "standalone"` in next.config.ts because
# middleware and API routes (NextAuth) require a Node.js server at runtime.
# Static export (nginx) is NOT compatible with this architecture.
# ---------------------------------------------------------------------------

# ---- Stage 1: Dependencies ----
FROM node:22-alpine AS deps

WORKDIR /app

# Copy dependency manifests first for better layer caching.
COPY package.json package-lock.json* ./

# Install dependencies deterministically.
RUN npm ci

# ---- Stage 2: Build ----
FROM node:22-alpine AS build

WORKDIR /app

# Copy dependencies from the deps stage.
COPY --from=deps /app/node_modules ./node_modules

# Copy the rest of the application source.
COPY . .

# Produce the standalone production build output.
RUN npm run build

# ---- Stage 3: Runtime ----
FROM node:22-alpine AS runtime

WORKDIR /app

# Create a non-root user for running the application.
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy the public assets from the build stage.
COPY --from=build /app/public ./public

# Copy the standalone server output from the build stage.
# The standalone output includes a minimal Node.js server and all
# necessary dependencies already bundled.
COPY --from=build --chown=nextjs:nodejs /app/.next/standalone ./

# Copy the static assets generated by the build.
# These are not included in the standalone output and must be
# copied separately.
COPY --from=build --chown=nextjs:nodejs /app/.next/static ./.next/static

# Expose port 3000 for HTTP traffic (Next.js default).
EXPOSE 3000

# Set environment variables for production.
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Run as the non-root nextjs user.
USER nextjs

# Healthcheck to verify the container is serving traffic.
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1

# Start the standalone Node.js server.
CMD ["node", "server.js"]
