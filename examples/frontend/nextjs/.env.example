NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-change-me-in-production

# Keycloak OIDC
KEYCLOAK_ISSUER=http://localhost:8080/realms/iam-example
KEYCLOAK_CLIENT_ID=iam-frontend
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# Public Keycloak URL exposed to the browser (for federated logout).
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8080/realms/iam-example

# Docker only: internal URL for server-to-server communication with Keycloak.
# Set this when the Next.js container cannot reach localhost:8080 directly.
# KEYCLOAK_BACKEND_URL=http://iam-keycloak:8080/realms/iam-example
