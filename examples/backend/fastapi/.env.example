# ---------------------------------------------------------------------------
# Environment variables for the IAM FastAPI Example.
#
# Copy this file to .env and adjust values as needed.
# ---------------------------------------------------------------------------

# --- Application ---
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_BASE_URL=http://localhost:8000

# --- Keycloak OIDC ---
OIDC_ISSUER=http://localhost:8080/realms/iam-example
OIDC_CLIENT_ID=iam-backend

# Public Keycloak URL reachable by the browser (for federated logout).
# Only needed in Docker where OIDC_ISSUER points to an internal hostname.
# OIDC_ISSUER_PUBLIC=http://localhost:8080/realms/iam-example
OIDC_CLIENT_SECRET=change-me-in-production

# --- Session ---
SESSION_SECRET_KEY=change-me-to-a-different-random-secret
