# ---------------------------------------------------------------------------
# Environment variables for the IAM FastAPI Example.
#
# Copy this file to .env and adjust values as needed.
# ---------------------------------------------------------------------------

# --- Application ---
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_BASE_URL=http://localhost:8000

# --- Keycloak OIDC ---
OIDC_ISSUER=http://localhost:8080/realms/iam-example
OIDC_CLIENT_ID=iam-fastapi-client
OIDC_CLIENT_SECRET=change-me-to-your-client-secret

# --- Session ---
SESSION_SECRET_KEY=change-me-to-a-different-random-secret
