<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> - <%= t('app.title') %></title>
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/global.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <script src="/js/theme.js"></script>
</head>
<body>
  <div class="app-layout">
    <%- include('partials/header') %>

    <main class="app-main">
      <div class="page">
        <h1 class="page-title"><%= t('home.title') %></h1>
        <p class="page-subtitle"><%= t('home.subtitle') %></p>
        <p class="page-description"><%= t('home.description') %></p>

        <% if (user) { %>
          <div class="home-authenticated">
            <p class="home-greeting"><%= t('home.greeting', { name: displayName }) %></p>
            <a href="/dashboard" class="btn btn-primary"><%= t('home.goToDashboard') %></a>
          </div>
        <% } else { %>
          <div class="home-unauthenticated">
            <p class="home-cta-text"><%= t('home.ctaText') %></p>
            <a href="/auth/login" class="btn btn-primary"><%= t('home.signIn') %></a>
          </div>
        <% } %>
      </div>
    </main>

    <%- include('partials/footer') %>
  </div>
</body>
</html>
