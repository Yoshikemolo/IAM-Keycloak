# =========================================================================
# .gitattributes -- Linguist overrides for GitHub language statistics
# =========================================================================
# Only suppress files that genuinely are not source code (documentation,
# generated assets, vendored configs).  Application code in all languages
# (Java, TypeScript, Python, C#, Vue, HCL, Shell) should be counted.
# =========================================================================

# Documentation
*.md linguist-documentation
doc/** linguist-documentation
planning/** linguist-documentation

# Generated / vendored assets (not application code)
assets/fonts/** linguist-vendored
assets/tech-logos/** linguist-vendored

# Infrastructure config files (keep HCL/Terraform visible)
infra/config/** linguist-vendored
docker-compose*.yml linguist-vendored
Dockerfile linguist-vendored
*.helmignore linguist-vendored

# Ensure key languages are detected as source code
*.ts linguist-detectable
*.tsx linguist-detectable
*.vue linguist-detectable
*.py linguist-detectable
*.cs linguist-detectable
*.java linguist-detectable
*.tf linguist-detectable
*.sh linguist-detectable
